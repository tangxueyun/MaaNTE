{
    "task": [
        {
            "name": "NaviWebSocket",
            "label": "$task_navi_websocket_label",
            "description": "$task_navi_websocket_desc",
            "entry": "NaviWebSocket",
            "option": [
                "NaviWebSocketSettings"
            ],
            "group": [
                "RealTimeAssist"
            ]
        }
    ],
    "option": {
        "NaviWebSocketSettings": {
            "type": "input",
            "label": "$task_navi_websocket_option_settings",
            "description": "$task_navi_websocket_option_settings_desc",
            "inputs": [
                {
                    "name": "host",
                    "label": "$task_navi_websocket_input_host",
                    "default": "0.0.0.0",
                    "pipeline_type": "string",
                    "verify": "^.+$"
                },
                {
                    "name": "port",
                    "label": "$task_navi_websocket_input_port",
                    "default": "14514",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                },
                {
                    "name": "frame_interval",
                    "label": "$task_navi_websocket_input_frame_interval",
                    "description": "$task_navi_websocket_input_frame_interval_desc",
                    "default": "0.1",
                    "pipeline_type": "string",
                    "verify": "^\\d+(\\.\\d+)?$"
                },
                {
                    "name": "angle_backend",
                    "label": "$task_navi_websocket_option_angle_backend",
                    "description": "$task_navi_websocket_option_angle_backend_desc",
                    "default": "auto",
                    "pipeline_type": "string",
                    "verify": "^(auto|directml|cpu)$"
                },
                {
                    "name": "debug",
                    "label": "$task_navi_websocket_option_debug",
                    "description": "$task_navi_websocket_option_debug_desc",
                    "default": "false",
                    "pipeline_type": "bool",
                    "verify": "^(true|false)$"
                }
            ],
            "pipeline_override": {
                "NaviWebSocket": {
                    "custom_action_param": {
                        "host": "{host}",
                        "port": "{port}",
                        "frame_interval": "{frame_interval}",
                        "angle_backend": "{angle_backend}",
                        "debug": "{debug}"
                    }
                }
            }
        }
    }
}
