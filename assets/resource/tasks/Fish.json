{
    "task": [
        {
            "name": "Fish",
            "label": "$task_fish_label",
            "entry": "FishEntrance",
            "option": [
                "FishLoopInfinite",
                "FishNumber",
                "FishSellAuto",
                "FishBuyBaitAuto"
            ]
        },
        {
            "name": "FishNew",
            "label": "$task_fish_new_label",
            "entry": "FishNewEntrance",
            "description": "$task_fish_new_desc",
            "option": [
                "FishSellAuto",
                "FishBuyBaitAuto"
            ]
        }
    ],
    "option": {
        "FishLoopTime": {
            "type": "input",
            "label": "$task_fish_option_loop_time",
            "description": "$task_fish_option_loop_time_desc",
            "inputs": [
                {
                    "name": "max_hit",
                    "label": "$task_fish_option_loop_time",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishStart": {
                    "max_hit": "{max_hit}"
                }
            }
        },
        "FishNumber": {
            "type": "input",
            "label": "$task_fish_option_count",
            "description": "$task_fish_option_count_desc",
            "inputs": [
                {
                    "name": "count",
                    "label": "$task_fish_option_count_input",
                    "default": "99",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishGameStart": {
                    "custom_action_param": {
                        "count": "{count}"
                    }
                }
            }
        },
        "FishLoopInfinite": {
            "type": "switch",
            "label": "$task_fish_option_infinite",
            "description": "$task_fish_option_infinite_desc",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "FishEntrance": {
                            "next": [
                                "FishLoopStart"
                            ]
                        },
                        "FishGameStart": {
                            "next": [
                                "AutoSellFish",
                                "AutoBuyFishBait",
                                "FishLoopStart"
                            ]
                        },
                        "AutoSellFish": {
                            "next": [
                                "AutoBuyFishBait",
                                "FishLoopStart"
                            ]
                        },
                        "AutoBuyFishBait": {
                            "next": [
                                "FishLoopStart"
                            ]
                        },
                        "FishBaitHandled": {
                            "next": [
                                "FishLoopStart"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "option": [
                        "FishLoopTime"
                    ]
                }
            ]
        },
        "FishSellAuto": {
            "type": "switch",
            "label": "$task_fish_option_auto_sell",
            "description": "$task_fish_option_auto_sell_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": true
                        },
                        "FishNewOpenFishMaster": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": false
                        },
                        "FishNewOpenFishMaster": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FishBuyBaitAuto": {
            "type": "switch",
            "label": "$task_fish_option_auto_buy_bait",
            "description": "$task_fish_option_auto_buy_bait_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": true
                        },
                        "FishGotoBuyBait": {
                            "enabled": true
                        },
                        "FishNewGotoBuyBait": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "FishBaitThreshold"
                    ]
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": false
                        },
                        "FishGotoBuyBait": {
                            "enabled": false
                        },
                        "FishNewGotoBuyBait": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FishBaitThreshold": {
            "type": "select",
            "label": "$task_fish_option_bait_threshold",
            "description": "$task_fish_option_bait_threshold_desc",
            "cases": [
                {
                    "name": "0.8",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.8
                            }
                        }
                    }
                },
                {
                    "name": "0.7",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.7
                            }
                        }
                    }
                },
                {
                    "name": "0.6",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.6
                            }
                        }
                    }
                },
                {
                    "name": "0.5",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.5
                            }
                        }
                    }
                },
                {
                    "name": "0.4",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.4
                            }
                        }
                    }
                }
            ]
        }
    }
}
