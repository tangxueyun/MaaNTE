{
    "task": [
        {
            "name": "钓鱼任务",
            "entry": "FishEntrance",
            "option": [
                "FishLoopInfinite",
                "FishNumber",
                "FishSellAuto",
                "FishBuyBaitAuto"
            ]
        },
        {
            "name": "钓鱼任务（新）",
            "entry": "FishNewEntrance",
            "description": "重构的钓鱼功能。理论上目前能无限钓鱼。<br><span style='color:red'>仍无法直接处理被月卡打断的跨夜钓鱼，可以尝试设置定时任务来继续钓鱼，实际效果无法保证。</span><br>钓鱼功能仅自动买鱼饵和自动卖鱼抢占鼠标。<br>自动买鱼饵为识别到鱼饵不足时购买或切换为万能鱼饵（鱼饵识别阈值与本任务无关），卖鱼也是在鱼鳞币不足时尝试卖",
            "option": [
                "FishSellAuto",
                "FishBuyBaitAuto"
            ]
        }
    ],
    "option": {
        "FishLoopTime": {
            "type": "input",
            "label": "循环次数",
            "description": "循环执行多少次钓鱼任务",
            "inputs": [
                {
                    "name": "max_hit",
                    "label": "循环次数",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishStart": {
                    "max_hit": "{max_hit}"
                }
            }
        },
        "FishNumber": {
            "type": "input",
            "label": "每次钓鱼数量",
            "description": "设置每次循环自动钓鱼的数量，建议小于等于99",
            "inputs": [
                {
                    "name": "count",
                    "label": "数量",
                    "default": "99",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "FishGameStart": {
                    "custom_action_param": {
                        "count": "{count}"
                    }
                },
                "FishNewCast": {
                    "max_hit": "{count}"
                }
            }
        },
        "FishLoopInfinite": {
            "type": "switch",
            "label": "无限循环",
            "description": "启用后钓鱼任务将无限循环，直到手动停止。",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "FishEntrance": {
                            "next": [
                                "FishLoopStart"
                            ]
                        },
                        "FishGameStart": {
                            "next": [
                                "AutoSellFish",
                                "AutoBuyFishBait",
                                "FishLoopStart"
                            ]
                        },
                        "AutoSellFish": {
                            "next": [
                                "AutoBuyFishBait",
                                "FishLoopStart"
                            ]
                        },
                        "AutoBuyFishBait": {
                            "next": [
                                "FishLoopStart"
                            ]
                        },
                        "FishBaitHandled": {
                            "next": [
                                "FishLoopStart"
                            ]
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "option": [
                        "FishLoopTime"
                    ]
                }
            ]
        },
        "FishSellAuto": {
            "type": "switch",
            "label": "自动卖鱼",
            "description": "是否启用自动卖鱼功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": true
                        },
                        "FishNewOpenFishMaster": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": false
                        },
                        "FishNewOpenFishMaster": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FishBuyBaitAuto": {
            "type": "switch",
            "label": "自动买鱼饵",
            "description": "每次自动购买99（上限）鱼饵",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": true
                        },
                        "FishGotoBuyBait": {
                            "enabled": true
                        },
                        "FishNewGotoBuyBait": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "FishBaitThreshold"
                    ]
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": false
                        },
                        "FishGotoBuyBait": {
                            "enabled": false
                        },
                        "FishNewGotoBuyBait": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "FishBaitThreshold": {
            "type": "select",
            "label": "鱼饵识别阈值",
            "description": "如果无法识别点击鱼饵位置，请调低该数值",
            "cases": [
                {
                    "name": "0.8",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.8
                            }
                        }
                    }
                },
                {
                    "name": "0.7",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.7
                            }
                        }
                    }
                },
                {
                    "name": "0.6",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.6
                            }
                        }
                    }
                },
                {
                    "name": "0.5",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.5
                            }
                        }
                    }
                },
                {
                    "name": "0.4",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "custom_action_param": {
                                "found_bait_threshold": 0.4
                            }
                        }
                    }
                }
            ]
        }
    }
}
