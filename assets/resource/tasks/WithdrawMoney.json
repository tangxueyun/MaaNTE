{
    "task": [
        {
            "name": "WithdrawMoney",
            "label": "$task_withdraw_money_label",
            "entry": "WithdrawMoneyEntrance",
            "description": "$task_withdraw_money_desc",
            "option": [
                "Restock"
            ],
            "controller": [
                "Win32",
                "Win32-Front"
            ]
        }
    ],
    "option": {
        "Restock": {
            "type": "switch",
            "label": "$task_withdraw_money_option_restock",
            "description": "$task_withdraw_money_option_restock_desc",
            "cases": [
                {
                    "name": "Yes",
                    "label": "$option_switch_case_yes",
                    "pipeline_override": {
                        "点击补货": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "$option_switch_case_no",
                    "pipeline_override": {
                        "点击补货": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "No"
        }
    }
}
