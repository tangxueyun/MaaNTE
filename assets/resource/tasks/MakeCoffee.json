{
    "task": [
        {
            "name": "MakeCoffee",
            "label": "$task_make_coffee_label",
            "desc": "$task_make_coffee_desc",
            "entry": "AutoMakeCoffee",
            "option": [
                "MakeCoffeeLoopTime"
            ]
        }
    ],
    "option": {
        "MakeCoffeeLoopTime": {
            "label": "$task_make_coffee_option_loop_time",
            "type": "input",
            "inputs": [
                {
                    "name": "LoopTime",
                    "default": "10",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "AutoMakeCoffee": {
                    "custom_action_param": {
                        "count": "{LoopTime}"
                    }
                }
            }
        }
    }
}
