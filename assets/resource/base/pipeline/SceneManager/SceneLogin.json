{
    "__ScenePrivateLogin": {
        "desc": "处理登录界面",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "__ScenePrivateCloseLoginAnnouncement",
                    "__ScenePriviteLoginExitButton"
                ]
            }
        },
        "next": [
            "__ScenePrivateLoginContinue",
            "[JumpBack]__ScenePrivateCloseLoginAnnouncement",
            "__ScenePrivateLogin"
        ]
    },
    "__ScenePriviteLoginExitButton": {
        "desc": "登录界面退出按钮",
        "recognition": "TemplateMatch",
        "roi": [
            0,
            -100,
            100,
            100
        ],
        "template": [
            "Common/Scene/Login/LoginExit.png"
        ],
        "green_mask": true,
        "pre_delay": 0,
        "post_delay": 0
    },
    "__ScenePrivateLoginContinue": {
        "desc": "等待登录页面出现按钮继续",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    400,
                    550,
                    480,
                    140
                ],
                "expected": [
                    "游戏",
                    "遊戲",
                    "GAME",
                    "Game",
                    "ゲーム",
                    "게임"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "__ScenePrivateAnyEnterWorldSuccess",
            "[JumpBack]__ScenePrivateLoginMonthlyPassConfirm",
            "[JumpBack]__ScenePrivateLoginLoading",
            "[JumpBack]__ScenePrivateAnyExit"
        ]
    },
    "__ScenePrivateCloseLoginAnnouncement": {
        "desc": "关闭登录时公告界面",
        "recognition": "And",
        "all_of": [
            "__ScenePrivateCloseAnnouncementButton",
            {
                "recognition": {
                    "type": "OCR",
                    "param": {
                        "roi": [
                            429,
                            88,
                            413,
                            69
                        ],
                        "expected": [
                            "公告",
                            "NOTICE",
                            "Notice",
                            "お知らせ",
                            "공지"
                        ]
                    },
                    "desc": "识别是否在公告界面"
                }
            }
        ],
        "action": {
            "type": "Click"
        }
    },
    "__ScenePrivateCloseAnnouncementButton": {
        "recognition": "TemplateMatch",
        "roi": [
            1090,
            84,
            70,
            70
        ],
        "template": [
            "Common/Scene/Login/LoginAnnouncementClose.png"
        ],
        "green_mask": true,
        "pre_delay": 0,
        "post_delay": 0
