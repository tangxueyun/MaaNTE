{
    "__ScenePrivateNextTrue": {
        "desc": "识别结果永远为真，用于退出next循环"
    },
    "__ScenePrivateAnyExit": {
        "desc": "退出当前场景，返回上一个场景",
        "pre_delay": 0,
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 27 // ESC
            }
        },
        "post_wait_freezes": {
            "target": [
                0,
                0,
                100,
                100
            ],
            "time": 600,
            "threshold": 0.85
        },
        "post_delay": 0
    },
    "__ScenePrivateLoading": {
        "desc": "判断当前在加载场景中",
        "recognition": "TemplateMatch",
        "template": [
            "Common/Scene/SceneLoading.png"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[JumpBack]__ScenePrivateLoading",
            "__ScenePrivateNextTrue"
        ]
    }
}
