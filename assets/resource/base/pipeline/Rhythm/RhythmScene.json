            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    1280,
                    720
                ],
                "template": [
                    "auto_rhythm/scene_templates/playing/pause.png"
                ]
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "RhythmSceneOnResults": {
        "desc": "判断正在结算界面",
        "recognition": {
            "type": "OCR",
