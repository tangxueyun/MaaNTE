{
    "PinkPawHeist_Main": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "DoNothing"
        },
        "next": [
            "PinkPawHeist_Loop"
        ],
        "focus": {
            "Node.Action.Starting": {
                "content": "{name} 即将开始执行，请确保你设置了**结束任务**的**全局快捷键**！",
                "display": "modal"
            }
        }
    },
    "PinkPawHeist_AutoResizeGameWindowConfig": {
        "enabled": false,
        "attach": {
            "auto_resize_game_window": true
        }
    },
    "PinkPawHeist_Loop": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "DoNothing"
        },
        "next": [
            {
                "name": "PinkPawHeist_CoreSequence",
                "jump_back": true
            },
            "PinkPawHeist_Finish"
        ]
    },
    "PinkPawHeist_Finish": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "StopTask"
        }
    },
    "PinkPawHeist_CoreSequence": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": {
            "type": "DoNothing"
        },
        "next": [
            "[JumpBack]PinkPawHeist_OCR_Join",
            "PinkPawHeist_FindXiaoZhi"
        ]
    },
    "PinkPawHeist_FindXiaoZhi": {
        "desc": "寻找小吱；找不到则尝试回到粉爪入口",
        "recognition": {
            "type": "DirectHit"
        },
        "action": "Custom",
        "custom_action": "PinkPawHeistFindXiaoZhiAction",
        "next": [
            "PinkPawHeist_OCR_Join",
            "PinkPawHeist_PressF"
        ],
        "on_error": [
            "PinkPawHeist_StopTask"
        ],
        "focus": {
            "Node.Action.Starting": {
                "content": "开始寻找小吱",
                "display": [
                    "log",
                    "toast"
                ]
            },
            "Node.Action.Failed": {
                "content": "❌ 未找到小吱且恢复失败，请手动回到小吱面前重新开始",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    },
    "PinkPawHeist_DetectXiaoZhi": {
        "desc": "检测小吱交互按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "小吱",
                    "小岐", // @i18n-skip
                    "小咕", // @i18n-skip
                    "(?i)Chiz",
                    "ちぃちゃん",
                    "치즈"
                ],
                "roi": [
                    765,
                    374,
                    209,
                    37
                ]
            }
        },
        "action": {
            "type": "DoNothing"
        },
        "next": [],
        "focus": {
            "Node.Action.Starting": {
                "content": "开始寻找小吱",
                "display": [
                    "log",
                    "toast"
                ]
            },
            "Node.Action.Failed": {
                "content": "未找到小吱，准备尝试回到粉爪入口",
                "display": [
                    "log",
                    "toast"
                ]
            },
            "Node.Action.Succeeded": {
                "content": "✅ 成功找到小吱，开始任务",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    },
    "PinkPawHeist_RecoverXiaoZhi": {
        "desc": "找不到小吱时尝试回到粉爪入口",
        "recognition": {
            "type": "DirectHit"
        },
        "action": "Custom",
        "custom_action": "PinkPawHeistReturnToEntranceAction",
        "next": [
            "[JumpBack]PinkPawHeist_OCR_Join",
