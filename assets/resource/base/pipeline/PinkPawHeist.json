        ],
        "focus": {
            "Node.Action.Starting": {
                "content": "未找到小吱，尝试传送并跑回粉爪入口",
                "display": [
                    "log",
                    "toast"
                ]
            },
            "Node.Action.Failed": {
                "content": "❌ 回到粉爪入口失败，请手动回到小吱面前重新开始",
                "display": [
                    "log",
                    "toast"
                ]
            }
        }
    },
