    "ClaimRewardsBattlePassRewards": {
        "desc": "领取历练奖赏",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    782,
                    568,
                    217,
                    49
                ],
                "expected": [
                    "全部领取",
                    "全部領取",
                    "(?i)Claim\\s*All",
                    "一括受取",
                    "모두 수령"
                ],
                "threshold": 0.8
            }
        },
        "action": "Click"
    },
    "ClaimRewardsExit": {
        "desc": "领取奖励任务出口",
        "pre_delay": 0,
        "post_delay": 0,
