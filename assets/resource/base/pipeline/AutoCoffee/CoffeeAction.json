{
    "MakeCoffeeScrollToTop": {
        "desc": "向上滚动到顶部",
        "action": "Scroll",
        "target": [
            110,
            260
        ],
        "dy": 2800
    },
    "MakeCoffeeEnterShop": {
        "desc": "通过OCR识别店长特供并点击进入",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    800,
                    359,
                    65,
                    26
                ],
                "expected": [
                    "店长特供",
                    "店長精選",
                    "(?i)Owner\\s*'\\s*s\\s*Selection",
                    "店長スペシャル"
                ],
                "threshold": 0.75
            ,
                "roi_offset": [
                    0,
                    0,
                    65,
                    0
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "alt_click"
            }
        },
        "post_wait_freezes": 1000
    },
    "MakeCoffeeEnterShopTemplate": {
        "desc": "模板匹配店长特供作为备用方案",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    800,
                    359,
                    65,
                    26
                ],
                "template": [
                    "auto_make_coffee/mgr_special.png",
                    "auto_make_coffee/mgr_special_2.png"
                ],
                "threshold": 0.75
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "alt_click"
            }
        }
    }
}
