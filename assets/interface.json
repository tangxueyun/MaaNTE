{
    "interface_version": 2,
    "name": "MaaNTE",
    "description": "$description",
    "contact": "$contact",
    "license": "[GNU Affero General Public License v3.0 (AGPL-3.0)](https://github.com/MaaEnd/MaaEnd/blob/v2/LICENSE)",
    "welcome": "$welcome.file",
    "github": "https://github.com/1bananachicken/MaaNTE",
    "icon": "logo.ico",
    "version": "0.0.4",
    "mirrorchyan_rid": "MaaNTE",
    "mirrorchyan_multiplatform": true,
    "languages": {
        "zh_cn": "resource/locales/interface/zh_cn.json",
        "zh_tw": "resource/locales/interface/zh_tw.json",
        "en_us": "resource/locales/interface/en_us.json",
        "ja_jp": "resource/locales/interface/ja_jp.json",
        "ko_kr": "resource/locales/interface/ko_kr.json"
    },
    "controller": [
        {
            "name": "Win32",
            "label": "$controller_default_label",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "PostMessage"
            }
        },
        {
            "name": "Win32-Front",
            "label": "$controller_front_label",
            "type": "Win32",
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "Seize",
                "keyboard": "PostMessage"
            }
        },
        {
            "name": "Win32-Background",
            "label": "$controller_background_label",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "label": "$resource_official_label",
            "path": [
                "resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "group": [
        {
            "name": "Daily",
            "label": "$group.Daily.label",
            "default_expand": true
        },
        {
            "name": "CityTycoon",
            "label": "$group.CityTycoon.label",
            "default_expand": true
        },
        {
            "name": "HethereauHobbies",
            "label": "$group.HethereauHobbies.label",
            "default_expand": true
        },
        {
            "name": "RealTimeAssist",
            "label": "$group.RealTimeAssist.label",
            "default_expand": true
        },
        {
            "name": "DatasetCollection",
            "label": "$group.DatasetCollection.label",
            "default_expand": true
        }
    ],
    "task": [
        {
            "name": "MapLocator",
            "entry": "MapLocator"
        },
        {
            "name": "NaviWebSocket",
            "label": "在线地图实时定位",
            "description": "打开在线地图，将实时位置和方向指针直接显示在原始网页地图图层中。",
            "entry": "NaviWebSocket",
            "group": [
                "RealTimeAssist"
            ]
        },
        {
            "name": "AnglePredictor",
            "entry": "AnglePredictor"
        }
    ],
    "import": [
        // group:Daily
        "resource/tasks/ClaimRewards.json",
        // group:CityTycoon
        "resource/tasks/Furniture.json",
        "resource/tasks/WithdrawMoney.json",
        // group:HethereauHobbies
        "resource/tasks/Fish.json",
        "resource/tasks/PinkPawHeist.json",
        "resource/tasks/MakeCoffee.json",
        "resource/tasks/Rhythm.json",
        "resource/tasks/Tetris.json",
        // group:RealTimeAssist
        "resource/tasks/RealTime.json",
        "resource/tasks/SoundDodge.json",
        "resource/tasks/AutoFScroll.json",
        // group:others
        "resource/tasks/FountainCheckin.json",
        "resource/tasks/AutoPiano.json",
        // group:DatasetCollection
        "resource/tasks/AutonomousDrivingDataset.json",
        // preset
        "resource/tasks/preset/AFK.json",
        // "resource/tasks/preset/FullDaily.json",
        // "resource/tasks/preset/QuickDaily.json",
        "resource/tasks/preset/RealtimeAssistance.json"
    ],
    "option": {}
}
