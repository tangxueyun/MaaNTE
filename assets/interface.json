{
    "interface_version": 2,
    "name": "MaaNTE",
    "description": "异环小助手，由MAAFramework强力驱动！",
    "contact": "QQ群: 1103323319",
    "license": "[GNU Affero General Public License v3.0 (AGPL-3.0)](https://github.com/MaaEnd/MaaEnd/blob/v2/LICENSE)",
    "welcome": "# 欢迎使用 MaaNTE\n\n**MaaNTE 为免费开源项目，从未授权任何人以任何形式进行售卖。**\n- 如在闲鱼、淘宝等平台购买了本软件，请立即申请退款并举报商家\n- 可凭此弹窗截图要求退款，维护自身权益\n- 你付给倒卖者的每一分钱都会让开源社区更艰难\n\n> Mirror酱 是我们的合作伙伴，提供下载加速服务，不属于售卖行为\n\n---\n\n本软件开源免费，仅供学习交流使用。\n\n使用本软件产生的所有后果由使用者自行承担，与开发者团队无关。\n\n开发者团队拥有本项目的最终解释权。",
    "github": "https://github.com/1bananachicken/MaaNTE",
    "icon": "logo.ico",
    "version": "0.0.4",
    "mirrorchyan_rid": "MaaNTE",
    "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "Win32",
            "label": "桌面端-默认",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "Background",
                "mouse": "SendMessageWithCursorPos",
                "keyboard": "PostMessage"
            }
        },
        {
            "name": "Win32-Front",
            "label": "桌面端-前台",
            "type": "Win32",
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "Seize",
                "keyboard": "PostMessage"
            }
        },
        {
            "name": "Win32-Background",
            "label": "桌面端-后台",
            "type": "Win32",
            "permission_required": true,
            "win32": {
                "class_regex": "UnrealWindow",
                "window_regex": "^\\s*(异环|NTE)\\s*$",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "PostMessage"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [],
    "import": [
        "resource/tasks/WithdrawMoney.json",
        "resource/tasks/Furniture.json",
        "resource/tasks/ClaimRewards.json",
        "resource/tasks/Fish.json",
        "resource/tasks/RealTime.json",
        "resource/tasks/MakeCoffee.json",
        "resource/tasks/Rhythm.json",
        "resource/tasks/Tetris.json",
        "resource/tasks/FountainCheckin.json",
        "resource/tasks/SoundDodge.json",
        "resource/tasks/AutoFScroll.json",
        "resource/tasks/auto_piano.json"
    ],
    "option": {}
}
